{
	// fid.is PDS deployment configuration
	"name": "fid-pds",
	"main": "src/index.ts",
	"compatibility_date": "2025-12-02",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"workers_dev": false,
	"preview_urls": false,
	"observability": {
		"logs": {
		"enabled": false,
		"invocation_logs": true
		}
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "ACCOUNT",
				"class_name": "AccountDurableObject"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"AccountDurableObject"
			]
		}
	],
	"vars": {
		"WEBFID_DOMAIN": "fid.is",
		"QUICKAUTH_DOMAIN": "my.fid.is",
		"INITIAL_ACTIVE": "true",
		"ALLOWLIST_ENABLED": "true",
		// x402 agent account creation
		"X402_PRICE": "0.01",
		"X402_FACILITATOR_URL": "https://x402.org/facilitator",
		"OPTIMISM_RPC_URL": "https://mainnet.optimism.io"
		// X402_PAY_TO: set via `wrangler secret put X402_PAY_TO`
	},
	"routes": [
		{ "pattern": "fid.is/*", "zone_name": "fid.is" },
		{ "pattern": "*.fid.is/*", "zone_name": "fid.is" }
	],
	"r2_buckets": [
		{
			"binding": "BLOBS",
			"bucket_name": "fid-pds-blobs"
		}
	],
	"d1_databases": [
		{
			"binding": "USER_REGISTRY",
			"database_name": "fid-pds-registry",
			"database_id": "b4e695ee-0f60-4911-81ee-ac53751466c0"
		}
	]
}